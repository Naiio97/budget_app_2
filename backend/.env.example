# GoCardless Bank Account Data API
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Trading 212 API
TRADING212_API_KEY=

# App Settings
FRONTEND_URL=http://localhost:3000

# PostgreSQL (used by docker-compose db service)
