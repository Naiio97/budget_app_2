# GoCardless Bank Account Data API
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Trading 212 API
TRADING212_API_KEY=

# App Settings
FRONTEND_URL=http://localhost:3000
# CORS — čárkami oddělené povolené originy. Nevyplněné = default v config.py
# (produkční frontend + localhost:3000).
# CORS_ORIGINS=https://muj-frontend.example.com,http://localhost:3000
# Úroveň logování (DEBUG/INFO/WARNING) — DEBUG zapne podrobné logy syncu.
LOG_LEVEL=INFO
# Formát logů: "text" (čitelné, lokální vývoj) | "json" (strukturované, produkce).
# Dockerfile nastavuje json, lokálně nech text.
LOG_FORMAT=text

# PostgreSQL (used by docker-compose db service)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=budget_db

# Database Connection (povinné, format: postgresql+asyncpg://user:pass@host:port/db)
DATABASE_URL=postgresql+asyncpg://admin:change_me@db:5432/budget_db

# Auth — shared HS256 secret with frontend Auth.js. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET=
AUTH_JWT_TTL_HOURS=24
AUTH_ALLOWED_OAUTH_PROVIDERS=google,apple

# Google OAuth client ID — MUST be the same value Auth.js uses on the frontend
# (AUTH_GOOGLE_ID). The backend verifies Google ID tokens against this as the
# expected audience. Leave empty to disable Google login (it will fail closed).
GOOGLE_CLIENT_ID=

# Bootstrap user (one-shot): migration 0007 inserts a placeholder user so
# existing data rows can backfill user_id. Override these env vars before
# first `alembic upgrade head` if you want the placeholder to have your real
# email/name; otherwise delete it after registering your real account via
# `python backend/scripts/reassign_user_data.py --from 1 --to <your-id>`.
BOOTSTRAP_USER_EMAIL=bootstrap@local
BOOTSTRAP_USER_NAME=Bootstrap
