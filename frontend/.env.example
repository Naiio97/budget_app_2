# Backend API base URL — used by lib/api.ts at runtime AND by auth.ts at signin
# to call POST /auth/oauth-upsert.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth.js (NextAuth v5).
# AUTH_SECRET must be IDENTICAL to backend's AUTH_SECRET — both sides sign /
# verify the same HS256 JWT. Generate:
#   openssl rand -base64 64
AUTH_SECRET=

# Auth.js v5 needs AUTH_URL in production deployments (skips inference).
# AUTH_URL=https://your-frontend.example.com

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple OAuth — https://developer.apple.com → Sign in with Apple
# AUTH_APPLE_SECRET is the JWT-signed client secret (NOT the raw key).
# See: https://authjs.dev/getting-started/providers/apple
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
